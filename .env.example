# Base de datos (Neon)
DATABASE_URL=

# Auth (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# API-Football (api-sports.io)
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_LEAGUE_ID=1
API_FOOTBALL_SEASON=2026

# Torneo
NEXT_PUBLIC_TOURNAMENT_START=2026-06-11T19:00:00Z

# Pagos
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Mercado Pago (Argentina)
MP_ACCESS_TOKEN=
NEXT_PUBLIC_MP_PUBLIC_KEY=
# Secreto del webhook de MP (panel → Webhooks). Si se setea, se exige firma x-signature.
MP_WEBHOOK_SECRET=
# dLocal Go (resto de LatAm: Paraguay, Bolivia, etc.)
DLOCAL_GO_BASE_URL=https://api.dlocalgo.com
DLOCAL_GO_API_KEY=
DLOCAL_GO_SECRET_KEY=

# ── Slack (notificaciones internas: pagos, usuarios, errores, scoring) ──
# Bot token de la Slack App (xoxb-...), scope chat:write. Sin esto → no-op.
SLACK_BOT_TOKEN=
# Canal por defecto (ID "C0..." o "#nombre"; el bot debe estar invitado al canal).
SLACK_CHANNEL_DEFAULT=
# Canales por tipo de evento (opcionales; si faltan caen al DEFAULT).
SLACK_CHANNEL_PAGOS=
SLACK_CHANNEL_USERS=
SLACK_CHANNEL_ERRORES=
SLACK_CHANNEL_SCORING=
# Poné "1" para emitir también en local/preview (por defecto sólo en producción).
SLACK_NOTIFY_DEV=

# ── PostHog (analytics + session replay) ──
# Project API key (phc_...). Es publishable (va al cliente). Sin esto → no inicializa.
NEXT_PUBLIC_POSTHOG_KEY=
# Host de ingesta (nube US). Para la nube EU sería https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
